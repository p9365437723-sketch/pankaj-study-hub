{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "subscriptionStatus": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Folder": {
      "title": "Folder",
      "description": "User created folders",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "File": {
      "title": "File",
      "description": "User file metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "folderId": { "type": "string" },
        "size": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "size", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "User notes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "User's team members",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User document" },
    "/users/{uid}/folders/{folderId}": { "schema": "Folder", "description": "User folders" },
    "/users/{uid}/files/{fileId}": { "schema": "File", "description": "User files" },
    "/users/{uid}/notes/{noteId}": { "schema": "Note", "description": "User notes" },
    "/users/{uid}/teamMembers/{memberId}": { "schema": "TeamMember", "description": "User team members" }
  }
}
